NODE_ENV=development
PORT=8000

# Database and service URLs
MONGO_URI=mongodb://localhost:27017/churn_platform
ML_API_URL=http://localhost:8001
ML_API_TIMEOUT_MS=8000
FRONTEND_BASE_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Optional local dataset path for telecom imports
TELCO_DATASET_PATH=./ibm/Telco_customer_churn.xlsx

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_ISSUER=churn-platform-api
AUTH_REQUIRE_EMAIL_VERIFICATION=false
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=60
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
PASSWORD_RESET_RESEND_COOLDOWN_SECONDS=60

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CONTACT_INBOX_EMAIL=

# AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Custom model training
ML_TRAINING_PYTHON_CMD=python
ML_TRAINING_SERVICE_DIR=../../services/ml-training
ML_TRAINING_SCRIPT_PATH=../../services/ml-training/src/pipelines/train_custom_tenant_pipeline.py
ML_TRAINING_ARTIFACTS_DIR=../../services/ml-training/artifacts/tenants
ML_TRAINING_TIMEOUT_MS=1200000

# Upload storage
ONBOARDING_UPLOADS_DIR=./storage/onboarding
